# Backend environment variables for local development.
# In production, set PORT automatically if the hosting provider supplies it.

PORT=3000
CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173
NODE_ENV=development

# PostgreSQL connection string for Step 19 persistent quiz library.
# Render PostgreSQL and Supabase both provide a DATABASE_URL value.
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DATABASE
